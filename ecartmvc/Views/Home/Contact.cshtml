@{
    ViewData["Title"] = "Contact";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0 text-center p-5">
                <h2 class="mb-4">Contact Us</h2>
                <p class="lead mb-4">
                    We’re here to help! Reach out to us directly via email or WhatsApp Business for fast support.
                </p>
                <div class="d-flex flex-column align-items-center gap-4">
                    <a href="mailto:info@yourdomain.com" class="btn btn-outline-primary btn-lg w-75" style="max-width:350px;">
                        <i class="bi bi-envelope-fill me-2"></i> Email Us
                    </a>
                    <a href="https://wa.me/1234567890" target="_blank" class="btn btn-success btn-lg w-75" style="max-width:350px;">
                        <i class="bi bi-whatsapp me-2"></i> WhatsApp Business
                    </a>
                </div>
                <div class="mt-5">
                    <small class="text-muted d-block mb-2">
                        We typically respond within <strong>2 business days</strong>.
                    </small>
                    <small class="text-muted d-block">
                        Support hours: Monday – Friday, 9:00 AM – 6:00 PM.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>