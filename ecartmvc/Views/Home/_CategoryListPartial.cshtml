@model List<ecartmvc.Models.Category>
@if (Model != null && Model.Any())
{
    foreach (var cat in Model)
    {
        <div class="col-6 col-md-4 col-lg-3" data-aos="fade-up">
            <a href="/Products?cat=@cat.Id" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100 border-0 category-card">
                    <div class="card-body">
                        <i class="bi @cat.IconClass display-4 text-primary mb-3"></i>
                        <h6 class="fw-semibold">@cat.Name</h6>
                    </div>
                </div>
            </a>
        </div>
    }
}
else
{
    <p class="text-center text-muted">No categories available.</p>
}