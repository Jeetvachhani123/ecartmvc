@{
    ViewData["Title"] = "About Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="about-hero text-center py-5" style="background: linear-gradient(90deg, #1e1e2f 60%, #f4f6f9 100%); color: #fff;">
    <div class="container">
        <h1 class="display-4 fw-bold mb-3">About eCart</h1>
        <p class="lead mb-4">Empowering your shopping experience with technology, trust, and transparency.</p>
        <img src="~/images/ecartlogo.png" alt="eCart Logo" class="mb-3" style="background: #fff; border-radius: 50%; padding: 10px;">
    </div>
</section>

<section class="mission-section py-5 bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 mb-4 mb-md-0">
                <img src="https://images.unsplash.com/photo-1515168833906-d2a3b82b1a5e?auto=format&fit=crop&w=600&q=80" class="img-fluid rounded shadow" alt="Our Mission">
            </div>
            <div class="col-md-6">
                <h2 class="fw-bold mb-3" style="color: #1e1e2f;">Our Mission</h2>
                <p class="fs-5">
                    At <span class="fw-bold">eCart</span>, our mission is to make online shopping seamless, secure, and enjoyable for everyone. We believe in innovation, customer satisfaction, and building a community of happy shoppers and sellers.
                </p>
                <ul class="list-unstyled fs-5">
                    <li><i class="bi bi-check-circle-fill text-success"></i> Fast & Reliable Delivery</li>
                    <li><i class="bi bi-check-circle-fill text-success"></i> 24/7 Customer Support</li>
                    <li><i class="bi bi-check-circle-fill text-success"></i> Secure Payments</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="team-section py-5">
    <div class="container">
        <h2 class="text-center fw-bold mb-5" style="color: #1e1e2f;">Meet Our Team</h2>
        <div class="row justify-content-center">
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow text-center h-100">
                    <img src="https://randomuser.me/api/portraits/men/32.jpg" class="card-img-top rounded-circle mx-auto mt-4" style="width: 120px; height: 120px; object-fit: cover;" alt="Team Member">
                    <div class="card-body">
                        <h5 class="card-title mb-1">Amit Sharma</h5>
                        <p class="card-text text-muted mb-2">Founder & CEO</p>
                        <p class="card-text">Visionary leader with a passion for e-commerce and technology.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow text-center h-100">
                    <img src="https://randomuser.me/api/portraits/women/44.jpg" class="card-img-top rounded-circle mx-auto mt-4" style="width: 120px; height: 120px; object-fit: cover;" alt="Team Member">
                    <div class="card-body">
                        <h5 class="card-title mb-1">Priya Verma</h5>
                        <p class="card-text text-muted mb-2">Head of Operations</p>
                        <p class="card-text">Ensures smooth operations and top-notch customer service.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="card border-0 shadow text-center h-100">
                    <img src="https://randomuser.me/api/portraits/men/54.jpg" class="card-img-top rounded-circle mx-auto mt-4" style="width: 120px; height: 120px; object-fit: cover;" alt="Team Member">
                    <div class="card-body">
                        <h5 class="card-title mb-1">Rahul Singh</h5>
                        <p class="card-text text-muted mb-2">Lead Developer</p>
                        <p class="card-text">Crafts robust, scalable, and user-friendly solutions for eCart.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="values-section py-5 bg-light">
    <div class="container">
        <h2 class="text-center fw-bold mb-4" style="color: #1e1e2f;">Our Values</h2>
        <div class="row text-center">
            <div class="col-md-4 mb-3">
                <i class="bi bi-shield-lock" style="font-size: 2.5rem; color: #1e1e2f;"></i>
                <h5 class="mt-2">Trust</h5>
                <p>We prioritize your privacy and security in every transaction.</p>
            </div>
            <div class="col-md-4 mb-3">
                <i class="bi bi-lightbulb" style="font-size: 2.5rem; color: #1e1e2f;"></i>
                <h5 class="mt-2">Innovation</h5>
                <p>Constantly evolving to bring you the best shopping experience.</p>
            </div>
            <div class="col-md-4 mb-3">
                <i class="bi bi-people" style="font-size: 2.5rem; color: #1e1e2f;"></i>
                <h5 class="mt-2">Community</h5>
                <p>Building lasting relationships with our customers and partners.</p>
            </div>
        </div>
    </div>
</section>