@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="~/images/adminpagelogo.ico" width="100x100" />
    <title>@ViewData["Title"] - Admin Panel | eCart</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: #f4f6f9;
            margin: 0;
        }

        .sidebar {
            height: 100vh;
            width: 250px;
            position: fixed;
            top: 0;
            left: 0;
            background-color: #1e1e2f;
            color: white;
            padding-top: 60px;
        }

            .sidebar a {
                color: #cfd8dc;
                padding: 15px 20px;
                display: block;
                text-decoration: none;
                transition: all 0.2s ease-in-out;
            }

                .sidebar a:hover,
                .sidebar .active {
                    background-color: #343a40;
                    color: #ffffff;
                }

            .sidebar h4 {
                padding-left: 20px;
                margin-bottom: 1rem;
                color: #ffffff;
            }

        .content {
            margin-left: 250px;
            padding: 20px;
        }

        .navbar {
            position: fixed;
            top: 0;
            left: 250px;
            right: 0;
            background-color: #ffffff;
            border-bottom: 1px solid #dee2e6;
            z-index: 1000;
            padding: 0.5rem 1rem;
        }

            .navbar .nav-title {
                font-weight: 600;
            }

        .main-body {
            margin-top: 60px;
        }

        @@media (max-width: 768px) {
            .sidebar

        {
            width: 100%;
            position: relative;
            height: auto;
        }

        .content,
        .navbar {
            margin-left: 0;
        }

        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <h4><img src="~/images/adminpagelogo.ico" width="50x50" />eCart Admin</h4>
        <a asp-controller="Admin" asp-action="Dashboard" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>
        <a asp-controller="Admin" asp-action="ManageProducts" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ManageProducts" ? "active" : "")">
            <i class="bi bi-box-seam"></i> Manage Products
        </a>
        <a asp-controller="Admin" asp-action="ManageOrders" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ManageOrders" ? "active" : "")">
            <i class="bi bi-cart-check"></i> Manage Orders
        </a>
        <a asp-controller="Admin" asp-action="ManageUsers" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ManageUsers" ? "active" : "")">
            <i class="bi bi-people"></i> Manage Users
        </a>
        <a asp-controller="Admin" asp-action="AdminLogin">
            <i class="bi bi-box-arrow-right"></i> Logout
        </a>
    </div>

    <!-- Top Navbar -->
    <nav class="navbar shadow-sm">
        <div class="container-fluid d-flex justify-content-between">
            <span class="nav-title">@ViewData["Title"]</span>
            <span class="text-muted">Welcome, Admin</span>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="content main-body">
        @RenderBody()
    </div>

    @RenderSection("Scripts", required: false)

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
</body>
</html>
