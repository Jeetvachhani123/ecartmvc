@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="ecart - Your one-stop electronics eCommerce store" />
    <meta name="keywords" content="electronics, mobiles, laptops, gadgets, ecart" />
    <link rel="icon" type="image/x-icon" href="~/images/remove background an.ico" />
    <title>@ViewData["Title"] - ecart</title>

    <!-- Bootstrap & Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" />

    <!-- Custom CSS -->
    <style>
        body {
            font-family: "Segoe UI", Roboto, Arial, sans-serif;
            background-color: #f9f9f9;
        }

        .navbar-brand {
            font-size: 1.4rem;
            letter-spacing: -0.5px;
        }

        .navbar-nav .nav-link {
            font-weight: 500;
            transition: color 0.2s;
        }

            .navbar-nav .nav-link:hover {
                color: #0d6efd;
            }

        .dropdown-toggle::after {
            margin-left: 0.4rem;
        }

        footer h6, footer h4 {
            font-weight: 600;
        }

        footer ul li {
            margin-bottom: 0.4rem;
        }

            footer ul li a:hover {
                color: #fff !important;
            }

        .toast-container {
            z-index: 1100;
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container">
            <!-- Brand -->
            <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
                <img src="~/images/remove background an.ico" width="40" height="40" class="me-2" alt="ecart logo" />
                ecart
            </a>

            <!-- Toggler -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Menu -->
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Products">Products</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Orders/MyOrders">My Orders</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/AboutUs">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/Contact">Contact</a></li>
                </ul>

                <!-- Search Bar -->
                <form class="d-flex me-3" asp-controller="Products" asp-action="Search" method="get">
                    <input class="form-control me-2" type="search" name="query" placeholder="Search products..." aria-label="Search" />
                    <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search"></i></button>
                </form>

                <!-- Cart Icon -->
                <a href="/Cart/Index" class="btn btn-outline-dark position-relative me-3">
                    <i class="bi bi-cart" style="font-size: 1.2rem;"></i>
                    @await Component.InvokeAsync("CartCount")
                </a>

                <!-- User Dropdown -->
                @{
                    var username = Context.Session.GetString("Username");
                    var role = Context.Session.GetString("Role");
                }
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center link-dark text-decoration-none dropdown-toggle"
                       id="dropdownUserMenu" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="~/images/icons8-user-24.png" alt="User" width="32" height="32" class="rounded-circle me-2">
                        @if (!string.IsNullOrEmpty(username))
                        {
                            <span>@username</span>
                        }
                        else
                        {
                            <span>Account</span>
                        }
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="dropdownUserMenu">
                        @if (!string.IsNullOrEmpty(username))
                        {
                            <li><a class="dropdown-item" href="~/Account/Profile"><i class="bi bi-person-circle me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item" href="~/Account/Settings"><i class="bi bi-gear me-2"></i>Settings</a></li>
                            @if (role == "Admin")
                            {
                                <li><a class="dropdown-item" href="~/Admin/Dashboard"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</a></li>
                            }
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form method="post" asp-controller="Account" asp-action="Logout" class="m-0">
                                    <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Sign out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li><a class="dropdown-item" href="~/Account/Login"><i class="bi bi-box-arrow-in-right me-2"></i>Login</a></li>
                            <li><a class="dropdown-item" href="~/Account/Register"><i class="bi bi-person-plus me-2"></i>Register</a></li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white pt-5 pb-4 mt-5">
        <div class="container text-md-start">
            <div class="row gy-4">

                <!-- Brand + Newsletter -->
                <div class="col-md-4">
                    <h4 class="fw-bold text-uppercase mb-3">ecart</h4>
                    <p>Explore the latest tech gadgets at unbeatable prices. We deliver quality with trust.</p>
                    <form class="d-flex">
                        <input type="email" class="form-control me-2" placeholder="Your email" />
                        <button class="btn btn-primary">Subscribe</button>
                    </form>
                </div>

                <!-- Quick Links -->
                <div class="col-md-2">
                    <h6 class="text-uppercase fw-bold mb-3">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a href="/" class="text-white-50 text-decoration-none">Home</a></li>
                        <li><a href="/Products" class="text-white-50 text-decoration-none">Shop</a></li>
                        <li><a href="/Home/AboutUs" class="text-white-50 text-decoration-none">About us</a></li>
                        <li><a href="/Home/Contact" class="text-white-50 text-decoration-none">Contact</a></li>
                    </ul>
                </div>

                <!-- Categories -->
                <div class="col-md-3">
                    <h6 class="text-uppercase fw-bold mb-3">Categories</h6>
                    <ul class="list-unstyled">
                        <li><a href="/Products?category=mobiles" class="text-white-50 text-decoration-none">Mobiles</a></li>
                        <li><a href="/Products?category=laptops" class="text-white-50 text-decoration-none">Laptops</a></li>
                        <li><a href="/Products?category=accessories" class="text-white-50 text-decoration-none">Accessories</a></li>
                        <li><a href="/Products?category=tv" class="text-white-50 text-decoration-none">Televisions</a></li>
                        <li><a href="/Products?category=smartwatch" class="text-white-50 text-decoration-none">Smart Watch</a></li>
                        <li><a href="/Products?category=camera" class="text-white-50 text-decoration-none">Camera</a></li>
                        <li><a href="/Products?category=memory" class="text-white-50 text-decoration-none">Memory</a></li>
                        <li><a href="/Products?category=speaker" class="text-white-50 text-decoration-none">Speaker</a></li>
                        <li><a href="/Products?category=keyboardmouse" class="text-white-50 text-decoration-none">Keyboard Mouse</a></li>
                        <li><a href="/Products?category=refrigerator" class="text-white-50 text-decoration-none">Refrigerator</a></li>
                        <li><a href="/Products?category=computer" class="text-white-50 text-decoration-none">Computer</a></li>
                        <li><a href="/Products?category=playstation" class="text-white-50 text-decoration-none">Play Station</a></li>
                    </ul>
                </div>

                <!-- Contact -->
                <div class="col-md-3">
                    <h6 class="text-uppercase fw-bold mb-3">Get in Touch</h6>
                    <p class="text-white-50 mb-1"><i class="bi bi-telephone-fill me-2"></i>+91 98765 43210</p>
                    <p class="text-white-50"><i class="bi bi-envelope-fill me-2"></i>support@ecart.com</p>
                    <div class="mt-2">
                        <a href="#" class="text-white me-3"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-white me-3"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="text-white me-3"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-white"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
            </div>

            <hr class="border-light mt-4" />
            <div class="text-center text-white-50">
                © @DateTime.Now.Year ecart. All rights reserved.
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <!-- SignalR Client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        // Single connection instance
        window.connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")  // Make sure this matches your hub endpoint
            .withAutomaticReconnect()
            .build();

        // Event handlers
        connection.on("RefreshProducts", function() {
            if (document.getElementById('productContainer')) {
                fetch('/Home/GetProductsPartial')
                    .then(response => response.text())
                    .then(html => {
                        document.getElementById('productContainer').innerHTML = html;
                    });
            }
        });

        connection.on("RefreshCategories", function() {
            if (document.getElementById('categoryContainer')) {
                fetch('/Home/GetCategoriesPartial')
                    .then(response => response.text())
                    .then(html => {
                        document.getElementById('categoryContainer').innerHTML = html;
                    });
            }
        });

        connection.on("ReceiveOrderUpdate", function(orderId, status) {
            showToast(`Order #${orderId} status updated to ${status}`);
        });

        // Start connection
        connection.start().catch(err => console.error(err));

        // Toast notification function
        function showToast(message) {
            let toastContainer = document.getElementById("toastContainer");
            if (!toastContainer) {
                toastContainer = document.createElement("div");
                toastContainer.id = "toastContainer";
                toastContainer.className = "toast-container position-fixed bottom-0 end-0 p-3";
                document.body.appendChild(toastContainer);
            }

            const toastEl = document.createElement("div");
            toastEl.className = "toast align-items-center text-bg-primary border-0 mb-2";
            toastEl.setAttribute("role", "alert");
            toastEl.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">${message}</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>`;

            toastContainer.appendChild(toastEl);
            const toast = new bootstrap.Toast(toastEl, { delay: 4000 });
            toast.show();
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
