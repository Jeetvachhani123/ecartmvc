@model ProductsIndexViewModel
@{
    ViewData["Title"] = "Products";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <!-- Category Dropdown at the Top -->
    <form method="get" class="mb-4 d-flex align-items-center" style="max-width:400px;">
        <label for="categoryDropdown" class="me-2 mb-0 fw-bold">Category:</label>
        <select id="categoryDropdown" name="Category" class="form-select me-2" onchange="this.form.submit()">
            <option value="">All</option>
            @foreach (var category in Model.Categories)
            {
                if (category == Model.SelectedCategory)
                {
                    <option value="@category" selected>@category</option>
                }
                else
                {
                    <option value="@category">@category</option>
                }
            }
        </select>
        <input type="hidden" name="Brand" value="@Model.SelectedBrand" />
        <input type="hidden" name="Search" value="@Model.Search" />
        <input type="hidden" name="PriceRange" value="@Model.SelectedPriceRange" />
        <input type="hidden" name="Rating" value="@Model.SelectedRating" />
    </form>

    <div class="row">
        <!-- Sidebar: Filters (without categories) -->
        <aside class="col-md-3 mb-4">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    Filter by Brand
                </div>
                <div class="card-body">
                    <form method="get">
                        <input type="hidden" name="Category" value="@Model.SelectedCategory" />
                        <select name="Brand" class="form-select mb-3" onchange="this.form.submit()">
                            <option value="">All Brands</option>
                            @foreach (var brand in Model.Brands)
                            {
                                if (brand == Model.SelectedBrand)
                                {
                                    <option value="@brand" selected>@brand</option>
                                }
                                else
                                {
                                    <option value="@brand">@brand</option>
                                }
                            }
                        </select>

                        <label class="form-label">
                            Price up to: ₹<span id="priceValue">@Model.SelectedPriceRange</span>
                        </label>
                        <input type="range" class="form-range" min="@Model.MinPrice" max="@Model.MaxPrice" step="1"
                               name="PriceRange" value="@Model.SelectedPriceRange"
                               oninput="document.getElementById('priceValue').innerText = this.value"
                               onchange="this.form.submit()" />

                        <label class="form-label mt-3">Minimum Rating</label>
                        <select name="Rating" class="form-select" onchange="this.form.submit()">
                            <option value="">Any</option>
                            @for (int i = 5; i >= 1; i--)
                            {
                                if (Model.SelectedRating == i)
                                {
                                    <option value="@i" selected>@i &#9733; &amp; above</option>
                                }
                                else
                                {
                                    <option value="@i">@i &#9733; &amp; above</option>
                                }
                            }
                        </select>
                    </form>
                </div>
            </div>
        </aside>

        <!-- Main: Product Grid -->
        <main class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Products</h4>
                <form method="get" class="d-flex" style="max-width:300px;">
                    <input type="hidden" name="Category" value="@Model.SelectedCategory" />
                    <input type="text" name="Search" class="form-control me-2" placeholder="Search products..." value="@Model.Search" />
                    <button class="btn btn-outline-primary" type="submit">Search</button>
                </form>
            </div>

            <div class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var product in Model.Products)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm">
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="object-fit:cover; height:200px;">
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title">@product.Name</h5>
                                <p class="card-text mb-1"><strong>Brand:</strong> @product.Brand</p>
                                <p class="card-text mb-1"><strong>Price:</strong> ₹@product.Price</p>

                                <div class="mb-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= product.AverageRating)
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-secondary"></i>
                                        }
                                    }
                                </div>

                                <a href="/Products/Details/@product.Id" class="btn btn-outline-primary mt-auto">
                                    View Details
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Products.Any())
            {
                <div class="alert alert-info mt-4">No products found matching your criteria.</div>
            }
        </main>
    </div>
</div>
